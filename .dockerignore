# .dockerignore for the Go backend (root context)
# Prevents build secrets and unnecessary files from reaching the Docker daemon

# Version control
.git
.gitignore

# IDE / OS
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment files (never bake secrets into images)
.env
.env.*
!.env.example

# Pre-built binaries (we build inside Docker)
*.exe
*.dll
*.so
*.dylib

# Go build cache
.gocache/
vendor/

# Frontend (built separately in its own Dockerfile)
frontend/

# Docker files themselves
Dockerfile*
docker-compose*.yml
docker/

# Docs
*.md
README*

# Logs
*.log
