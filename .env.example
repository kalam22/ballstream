# Application
PORT=8081

# API credentials
API_KEY=replace-with-real-api-key
API_KEY_2=replace-with-second-api-key
API_BASE_URL=https://api.sportsrc.org/v2/
API_BASE_URL_2=

# Optional comma-separated host allowlist for embedded streams.
# Example: STREAM_EMBED_ALLOWLIST=embed.example.com,player.example.net
STREAM_EMBED_ALLOWLIST=

# CORS Configuration
# Comma-separated list of allowed origins (required for production)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Client API Keys (for frontend authentication)
# Generate secure random keys: openssl rand -hex 32
# Leave empty to disable authentication (development only)
CLIENT_API_KEYS=replace-with-secure-random-key

# API Authentication Mode
# Set to true to require API key for all endpoints (production)
# Set to false to allow public access to read-only endpoints (development)
API_AUTH_REQUIRED=false

# TLS Configuration (required for production)
TLS_CERT_FILE=/path/to/cert.pem
TLS_KEY_FILE=/path/to/key.pem

# App-level rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS_HTML=5
RATE_LIMIT_RPS_API=3
RATE_LIMIT_BURST_HTML=20
RATE_LIMIT_BURST_API=10

# Limit total upstream requests in flight across all handlers
UPSTREAM_MAX_INFLIGHT=8

# Trust X-Forwarded-For / X-Real-IP from your reverse proxy
TRUST_PROXY_HEADERS=false

# Expose Prometheus-style metrics internally at /internal/metrics
ENABLE_INTERNAL_METRICS=true
